NODE_ENV=development
HOST=127.0.0.1
PORT=8787
APP_NAME=Remote Codex Supervisor
APP_VERSION=0.1.0
WORKSPACE_ROOT=
DATABASE_URL=
REMOTE_CODEX_MODE=local
# Required when REMOTE_CODEX_MODE=server or REMOTE_CODEX_MODE=relay.
REMOTE_CODEX_ADMIN_USERNAME=
REMOTE_CODEX_ADMIN_PASSWORD=
REMOTE_CODEX_SESSION_SECRET=
REMOTE_CODEX_SESSION_TTL_SECONDS=604800
# Used by the home supervisor when REMOTE_CODEX_MODE=relay.
REMOTE_CODEX_RELAY_SERVER_URL=
REMOTE_CODEX_RELAY_AGENT_TOKEN=
REMOTE_CODEX_RELAY_SUPERVISOR_PORT=45679
# Used by apps/relay-server on the public relay server.
# Optional legacy bootstrap token. New devices should use tokens created in /relay-portal.
REMOTE_CODEX_RELAY_PORT=8798
REMOTE_CODEX_RELAY_SUPERVISOR_TOKEN=
REMOTE_CODEX_RELAY_DATA_DIR=
REMOTE_CODEX_RELAY_SESSION_SECRET=
REMOTE_CODEX_RELAY_REGISTRATION_ENABLED=true
REMOTE_CODEX_RELAY_WEB_DIST_DIR=
REMOTE_CODEX_HOSTED_SANDBOX_PROVIDER=disabled
REMOTE_CODEX_INCUS_HOST_AGENT_URL=
REMOTE_CODEX_INCUS_HOST_AGENT_TOKEN=
REMOTE_CODEX_INCUS_HOST_AGENT_TIMEOUT_MS=1500
CODEX_HOME=
CODEX_COMMAND=codex
CODEX_APP_SERVER_START_TIMEOUT_MS=10000
