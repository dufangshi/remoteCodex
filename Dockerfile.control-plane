FROM node:22-bookworm-slim AS base

ARG KUBECTL_VERSION=v1.34.2

ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=8790 \
    REMOTE_CODEX_PACKAGE_ROOT=/opt/remote-codex

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    build-essential \
    python3 \
    unzip \
  && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip \
  && unzip -q /tmp/awscliv2.zip -d /tmp \
  && /tmp/aws/install \
  && rm -rf /tmp/aws /tmp/awscliv2.zip

RUN curl -fsSL "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" -o /usr/local/bin/kubectl \
  && chmod +x /usr/local/bin/kubectl

RUN corepack enable

WORKDIR /opt/remote-codex

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY scripts/start-control-plane-railway.sh ./scripts/start-control-plane-railway.sh
COPY apps/control-plane-api ./apps/control-plane-api
COPY packages/config ./packages/config
COPY packages/db ./packages/db
COPY packages/shared ./packages/shared

RUN pnpm --filter @remote-codex/control-plane-api... install --frozen-lockfile \
  && pnpm --filter @remote-codex/control-plane-api build \
  && pnpm --filter @remote-codex/config build \
  && pnpm --filter @remote-codex/db build \
  && pnpm --filter @remote-codex/shared build \
  && chmod +x /opt/remote-codex/scripts/start-control-plane-railway.sh

EXPOSE 8790

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:8790/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["/opt/remote-codex/scripts/start-control-plane-railway.sh"]
