FROM node:22-bookworm-slim AS build

ARG VITE_CONTROL_PLANE_BASE_URL=http://127.0.0.1:8790
ARG FRONTEND_BUILD_SHA=unknown
ARG REMOTE_CODEX_THREAD_UI_DEPLOY_KEY_B64
ENV VITE_CONTROL_PLANE_BASE_URL=${VITE_CONTROL_PLANE_BASE_URL}

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    build-essential \
    git \
    openssh-client \
    python3 \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /opt/remote-codex

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY scripts/setup-thread-ui-git-auth.sh ./scripts/setup-thread-ui-git-auth.sh
COPY apps/supervisor-web ./apps/supervisor-web
COPY packages/plugin-runtime ./packages/plugin-runtime
COPY packages/plugin-terminal ./packages/plugin-terminal
COPY packages/plugin-xyz-viewer ./packages/plugin-xyz-viewer
COPY packages/shared ./packages/shared
COPY packages/thread-ui ./packages/thread-ui

RUN bash ./scripts/setup-thread-ui-git-auth.sh \
  && pnpm --filter @remote-codex/supervisor-web... install --frozen-lockfile \
  && pnpm --filter @remote-codex/plugin-runtime build \
  && pnpm --filter @remote-codex/plugin-terminal build \
  && pnpm --filter @remote-codex/plugin-xyz-viewer build \
  && pnpm --filter @remote-codex/shared build \
  && pnpm --filter @remote-codex/thread-ui build \
  && pnpm --filter @remote-codex/supervisor-web build \
  && printf '{"buildSha":"%s"}\n' "${FRONTEND_BUILD_SHA}" > apps/supervisor-web/dist/build.json \
  && bash ./scripts/setup-thread-ui-git-auth.sh --cleanup

FROM nginx:1.27-alpine

ENV PORT=8080

COPY infra/nginx/supervisor-web.conf.template /etc/nginx/templates/default.conf.template
COPY --from=build /opt/remote-codex/apps/supervisor-web/dist /usr/share/nginx/html

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- "http://127.0.0.1:${PORT}/healthz" >/dev/null || exit 1
