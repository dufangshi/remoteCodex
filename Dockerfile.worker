FROM node:22-bookworm-slim AS base

ARG REMOTE_CODEX_IMAGE_VERSION=development
ARG REMOTE_CODEX_GIT_SHA=unknown
ARG OPENAI_CODEX_VERSION=0.133.0
ARG ANTHROPIC_CLAUDE_CODE_VERSION=2.1.150
ARG ANTHROPIC_CLAUDE_AGENT_SDK_VERSION=0.3.150
ARG OPENCODE_AI_VERSION=1.15.10
ARG OPENCODE_AI_SDK_VERSION=1.15.10
ARG REMOTE_CODEX_THREAD_UI_DEPLOY_KEY_B64
ARG REMOTE_CODEX_THREAD_UI_REPO=https://github.com/dufangshi/remote-codex-thread-ui.git
ARG REMOTE_CODEX_THREAD_UI_REF=main

LABEL org.opencontainers.image.title="remote-codex-worker" \
      org.opencontainers.image.version="${REMOTE_CODEX_IMAGE_VERSION}" \
      org.opencontainers.image.revision="${REMOTE_CODEX_GIT_SHA}" \
      org.opencontainers.image.description="Remote Codex sandbox worker image"

ENV NODE_ENV=production \
    REMOTE_CODEX_PACKAGE_ROOT=/opt/remote-codex \
    REMOTE_CODEX_WORKER_RUNTIME_MANIFEST=/opt/remote-codex/worker-runtime-manifest.json \
    REMOTE_CODEX_DISABLE_BUILD_RESTART=true

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    git \
    openssh-client \
    python3 \
    ripgrep \
    tmux \
    unzip \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /opt/remote-codex

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY scripts/setup-thread-ui-git-auth.sh ./scripts/setup-thread-ui-git-auth.sh
COPY apps ./apps
COPY packages ./packages
COPY config ./config

RUN --mount=type=secret,id=remote_codex_thread_ui_deploy_key,required=false \
  REMOTE_CODEX_THREAD_UI_DEPLOY_KEY_FILE=/run/secrets/remote_codex_thread_ui_deploy_key \
  REMOTE_CODEX_THREAD_UI_DEPLOY_KEY_B64="${REMOTE_CODEX_THREAD_UI_DEPLOY_KEY_B64}" \
  bash ./scripts/setup-thread-ui-git-auth.sh \
  && pnpm install --frozen-lockfile \
  && pnpm --filter @remote-codex/supervisor-api build \
  && pnpm --filter @remote-codex/db build \
  && pnpm --filter @remote-codex/config build \
  && pnpm store prune \
  && bash ./scripts/setup-thread-ui-git-auth.sh --cleanup

RUN useradd --create-home --home-dir /home/agent --shell /bin/bash agent \
  && mkdir -p /workspace /home/agent/.remote-codex /home/agent/.codex /home/agent/.claude /home/agent/.opencode \
  && chown -R agent:agent /workspace /home/agent

RUN npm install -g \
    "@openai/codex@${OPENAI_CODEX_VERSION}" \
    "@anthropic-ai/claude-code@${ANTHROPIC_CLAUDE_CODE_VERSION}" \
    "@anthropic-ai/claude-agent-sdk@${ANTHROPIC_CLAUDE_AGENT_SDK_VERSION}" \
    "opencode-ai@${OPENCODE_AI_VERSION}" \
    "@opencode-ai/sdk@${OPENCODE_AI_SDK_VERSION}" \
  && OPENAI_CODEX_VERSION="${OPENAI_CODEX_VERSION}" \
    ANTHROPIC_CLAUDE_CODE_VERSION="${ANTHROPIC_CLAUDE_CODE_VERSION}" \
    ANTHROPIC_CLAUDE_AGENT_SDK_VERSION="${ANTHROPIC_CLAUDE_AGENT_SDK_VERSION}" \
    OPENCODE_AI_VERSION="${OPENCODE_AI_VERSION}" \
    OPENCODE_AI_SDK_VERSION="${OPENCODE_AI_SDK_VERSION}" \
    REMOTE_CODEX_IMAGE_VERSION="${REMOTE_CODEX_IMAGE_VERSION}" \
    REMOTE_CODEX_GIT_SHA="${REMOTE_CODEX_GIT_SHA}" \
    node -e "const fs=require('fs'); const manifest={imageVersion:process.env.REMOTE_CODEX_IMAGE_VERSION ?? 'development', gitSha:process.env.REMOTE_CODEX_GIT_SHA ?? 'unknown', generatedAt:new Date().toISOString(), runtimes:{codex:{package:'@openai/codex',version:process.env.OPENAI_CODEX_VERSION},claudeCode:{package:'@anthropic-ai/claude-code',version:process.env.ANTHROPIC_CLAUDE_CODE_VERSION},claudeAgentSdk:{package:'@anthropic-ai/claude-agent-sdk',version:process.env.ANTHROPIC_CLAUDE_AGENT_SDK_VERSION},opencode:{package:'opencode-ai',version:process.env.OPENCODE_AI_VERSION},opencodeSdk:{package:'@opencode-ai/sdk',version:process.env.OPENCODE_AI_SDK_VERSION}}}; fs.writeFileSync('/opt/remote-codex/worker-runtime-manifest.json', JSON.stringify(manifest, null, 2));"

USER agent
WORKDIR /workspace

EXPOSE 8787

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:8787/readyz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "/opt/remote-codex/apps/supervisor-api/dist/worker-index.js"]
