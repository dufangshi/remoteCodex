FROM node:22-bookworm-slim AS base

ARG REMOTE_CODEX_IMAGE_VERSION=development
ARG REMOTE_CODEX_GIT_SHA=unknown

LABEL org.opencontainers.image.title="remote-codex-worker" \
      org.opencontainers.image.version="${REMOTE_CODEX_IMAGE_VERSION}" \
      org.opencontainers.image.revision="${REMOTE_CODEX_GIT_SHA}" \
      org.opencontainers.image.description="Remote Codex sandbox worker image"

ENV NODE_ENV=production \
    REMOTE_CODEX_RUNTIME_ROLE=worker \
    HOST=0.0.0.0 \
    PORT=8787 \
    HOME=/home/agent \
    WORKSPACE_ROOT=/workspace \
    CODEX_HOME=/home/agent/.codex \
    CLAUDE_HOME=/home/agent/.claude \
    CLAUDE_CONFIG_DIR=/home/agent/.claude \
    OPENCODE_HOME=/home/agent/.opencode \
    DATABASE_URL=/home/agent/.remote-codex/worker.sqlite \
    REMOTE_CODEX_PACKAGE_ROOT=/opt/remote-codex \
    REMOTE_CODEX_DISABLE_BUILD_RESTART=true

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    openssh-client \
    ripgrep \
    tmux \
    unzip \
  && rm -rf /var/lib/apt/lists/*

RUN corepack enable

WORKDIR /opt/remote-codex

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY apps ./apps
COPY packages ./packages
COPY config ./config

RUN pnpm install --frozen-lockfile \
  && pnpm --filter @remote-codex/supervisor-api build \
  && pnpm --filter @remote-codex/db build \
  && pnpm --filter @remote-codex/config build \
  && pnpm store prune

RUN useradd --create-home --home-dir /home/agent --shell /bin/bash agent \
  && mkdir -p /workspace /home/agent/.remote-codex /home/agent/.codex /home/agent/.claude /home/agent/.opencode \
  && chown -R agent:agent /workspace /home/agent/.remote-codex /home/agent/.codex /home/agent/.claude /home/agent/.opencode

RUN npm install -g \
    @openai/codex \
    @anthropic-ai/claude-code \
    @anthropic-ai/claude-agent-sdk \
    opencode-ai \
    @opencode-ai/sdk

USER agent
WORKDIR /workspace

EXPOSE 8787

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:8787/readyz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))"

CMD ["node", "/opt/remote-codex/apps/supervisor-api/dist/worker-index.js"]
