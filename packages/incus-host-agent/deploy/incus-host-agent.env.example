REMOTE_CODEX_INCUS_HOST_AGENT_HOST=127.0.0.1
REMOTE_CODEX_INCUS_HOST_AGENT_PORT=8801
REMOTE_CODEX_INCUS_HOST_AGENT_TOKEN=replace-with-at-least-32-random-characters
REMOTE_CODEX_INCUS_PROJECT=remote-codex-hosted
REMOTE_CODEX_INCUS_INSTANCE_PREFIX=rcd-
REMOTE_CODEX_INCUS_IMAGE_VERSION=ubuntu-24.04-v1
REMOTE_CODEX_INCUS_IMAGE_SOURCE=images:ubuntu/24.04/cloud
REMOTE_CODEX_INCUS_MAX_CPU=2
REMOTE_CODEX_INCUS_MAX_MEMORY_MIB=2048
REMOTE_CODEX_INCUS_MAX_DISK_GIB=12
REMOTE_CODEX_INCUS_COMMAND_TIMEOUT_MS=120000
REMOTE_CODEX_INCUS_OPERATION_DIR=/var/lib/remote-codex-incus-host-agent/operations
REMOTE_CODEX_INCUS_AUDIT_LOG=/var/log/remote-codex-incus-host-agent/audit.jsonl
